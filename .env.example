# ───────────────────────────────────────────────────────────────
#  Claves de API — copia este archivo a .env y rellena los valores
# ───────────────────────────────────────────────────────────────
#
#  Las claves de pago son SERVER-SIDE (sin prefijo VITE_).
#  Sólo se leen en las Vercel Edge Functions de /api/*.
#  NUNCA las pongas en VITE_* — quedarían expuestas en el bundle.
#
#  Sin ninguna clave configurada la app funciona igual:
#  - datos de fixture desde rezarahiminia/worldcup2026 (sin clave)
#  - datos en vivo desde ESPN (sin clave)
#  - cuotas generadas por el modelo interno
#
# ─── CLIENT-SIDE (VITE_*) ───────────────────────────────────────

# Modo de proveedor legacy (puede quedar en "mock" si usas la capa de fusión)
VITE_DATA_PROVIDER=mock

# ─── SERVER-SIDE — Fuentes gratuitas / sin clave ────────────────
# ESPN (scoreboard) y rezarahiminia/worldcup2026 no necesitan clave.
# Se usan automáticamente vía /api/matches y /api/worldcup.

# ─── SERVER-SIDE — Fuentes de pago (opcionales) ─────────────────

# API-Football v3 (fixtures + standings + forma)
# Cuota: 100 req/día — https://www.api-football.com/
API_FOOTBALL_KEY=

# BALLDONTLIE (games + odds, si soportan FIFA WC 2026)
# https://www.balldontlie.io/
BALLDONTLIE_API_KEY=

# SportsGameOdds (odds multi-mercado, soccer WC)
# https://sportsgameodds.com/
SPORTSGAMEODDS_API_KEY=

# OddsPapi (odds 350+ casas — CUOTA MUY LIMITADA: 250 req/mes)
# Sólo se llama 2×/día por el cache CDN de 12 h
# https://oddspapi.com/
ODDSPAPI_API_KEY=

# ─── Vercel KV (cache de escritura para los Cron Jobs) ───────────
# Obtén estos valores en el panel de Vercel → Storage → KV Store
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── Cron secret (valida las llamadas de /api/cron/*) ───────────
# Genera con: openssl rand -hex 32
CRON_SECRET=
